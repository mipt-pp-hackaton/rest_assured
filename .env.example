# Application settings
DYNACONF_APP_SETTINGS__HOST=0.0.0.0
DYNACONF_APP_SETTINGS__PORT=8000
DYNACONF_APP_SETTINGS__USE_TESTCONTAINERS=False

# Database settings (Dynaconf)
DYNACONF_DB_SETTINGS__NAME=test_db
DYNACONF_DB_SETTINGS__USER=user
DYNACONF_DB_SETTINGS__PASSWORD=CHANGE_ME
DYNACONF_DB_SETTINGS__HOST=postgres
DYNACONF_DB_SETTINGS__PORT=5432

# JWT (override [jwt] section in settings.toml)
DYNACONF_JWT__SECRET=replace-with-32+-random-bytes
DYNACONF_JWT__TTL_HOURS=24
DYNACONF_JWT__ALGORITHM=HS256

# Scheduler settings (T2.1)
DYNACONF_SCHEDULER__POLL_INTERVAL_SECONDS=5
DYNACONF_SCHEDULER__DEFAULT_TIMEOUT_MS=5000

# Postgres credentials (consumed by docker-compose.prod.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=test_db

# Image versions (consumed by docker-compose.prod.yml)
APP_VERSION=1.1.0
TEST_SERVICE_VERSION=0.1.0

# API auth (T18)
API_KEY=CHANGE_ME_API_KEY

# SMTP settings (T4.1)
DYNACONF_SMTP__HOST=mailhog
DYNACONF_SMTP__PORT=1025
DYNACONF_SMTP__FROM_EMAIL=noreply@rest-assured.local

# Notification settings (T4.1)
DYNACONF_NOTIFICATIONS__REMINDER_COOLDOWN_MINUTES=30